{
    "name": "meraki/schema-json",
    "description": "JSON serialization and deserialization for meraki/schema.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Nathan Bishop",
            "email": "nbish11@hotmail.com"
        }
    ],
    "require": {
        "php": "^8.4",
        "meraki/schema": "@dev"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.3"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../schema",
            "options": {
                "symlink": true
            }
        }
    ],
    "minimum-stability": "dev",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "Meraki\\Schema\\Json\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Meraki\\Schema\\Json\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    }
}
